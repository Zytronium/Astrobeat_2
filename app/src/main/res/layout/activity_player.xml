<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/space_background"
    android:padding="20dp">

    <!-- top bar -->
    <ImageButton
        android:id="@+id/buttonBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_back"
        android:contentDescription="@string/back_button_description"
        android:tint="@color/cyan_accent" />

    <Space android:layout_width="match_parent" android:layout_height="28dp" />

    <!-- track info -->
    <TextView
        android:id="@+id/textTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/space_foreground"
        android:textSize="24sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/textArtistAlbum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- player card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_player_controls"
        android:padding="24dp">

        <!-- seekbar + timestamps -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/cyan_accent"
            android:progressBackgroundTint="#2A3050"
            android:thumb="@drawable/seek_thumb"
            android:max="1000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/textPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:text="0:00" />

            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

            <TextView
                android:id="@+id/textDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:text="0:00" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="20dp" />

        <!-- main controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- shuffle -->
            <ImageButton
                android:id="@+id/buttonShuffle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_inactive"
                android:src="@drawable/ic_shuffle"
                android:tint="@color/text_secondary"
                android:contentDescription="Shuffle"
                android:padding="10dp" />

            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

            <!-- previous -->
            <ImageButton
                android:id="@+id/buttonPrevious"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_skip_previous"
                android:tint="@color/space_foreground"
                android:contentDescription="Previous"
                android:padding="8dp" />

            <Space android:layout_width="12dp" android:layout_height="wrap_content" />

            <!-- play/pause -->
            <ImageButton
                android:id="@+id/buttonPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_play_button"
                android:src="@drawable/ic_play"
                android:tint="@color/space_background"
                android:contentDescription="Play/Pause"
                android:padding="16dp" />

            <Space android:layout_width="12dp" android:layout_height="wrap_content" />

            <!-- next -->
            <ImageButton
                android:id="@+id/buttonNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_skip_next"
                android:tint="@color/space_foreground"
                android:contentDescription="Next"
                android:padding="8dp" />

            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

            <!-- loop -->
            <ImageButton
                android:id="@+id/buttonLoop"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_inactive"
                android:src="@drawable/ic_repeat"
                android:tint="@color/text_secondary"
                android:contentDescription="Loop"
                android:padding="10dp" />

        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="20dp" />

        <!-- speed button -->
        <Button
            android:id="@+id/buttonSpeed"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:backgroundTint="#1A2A3A"
            android:text="1×"
            android:textColor="@color/cyan_accent"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="16dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <Space android:layout_width="match_parent" android:layout_height="16dp" />

</LinearLayout>
