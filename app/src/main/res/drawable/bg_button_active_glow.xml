<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- glow halo -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#3000E5FF" />
            <corners android:radius="50dp" />
        </shape>
    </item>
    <!-- inner circle -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="#2200E5FF" />
        </shape>
    </item>
</layer-list>